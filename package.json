{
	"name": "svelte-docs-starter",
	"version": "1.0.0",
	"description": "A modern, full-featured documentation starter built with SvelteKit, Tailwind CSS v4, shadcn-svelte, and MDSvex.",
	"author": "code-gio",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/code-gio/svelte-docs-starter"
	},
	"homepage": "https://github.com/code-gio/svelte-docs-starter",
	"bugs": {
		"url": "https://github.com/code-gio/svelte-docs-starter/issues"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"documentation",
		"docs",
		"starter",
		"template",
		"tailwindcss",
		"shadcn-svelte",
		"mdsvex",
		"markdown"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "pagefind --site .svelte-kit/output/prerendered/pages --output-path static/pagefind",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint . && prettier --check .",
		"clean": "node scripts/clean.js"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"pagefind": "^1.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-eslint-parser": "^1.6.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@shikijs/transformers": "^4.0.2",
		"mdsvex": "^0.12.7",
		"shiki": "^4.0.2"
	}
}
